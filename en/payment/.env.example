# ==========================================
# BantouMind AI - Chariow Payment Config
# ==========================================
# Obtenez votre clé API : https://app.chariow.com/settings/api

# Clé API secrète (commence par sk_live_ ou sk_test_)
CHARIOW_API_KEY=sk_live_votre_cle_api_ici

# ID des produits (à créer sur https://app.chariow.com/products)
# Utilisez node chariow-payment.js --list-products pour voir vos produits
# PRODUCT_ID_WHATSAPP=prd_xxx
# PRODUCT_ID_BUNDLE=prd_xxx
